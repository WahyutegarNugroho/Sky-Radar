# =============================================================================
# SkyRadar Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# --- Database (Supabase PostgreSQL) ---
# Connection string for runtime (transaction mode via pooler, port 6543)
# Replace with your Supabase project URL
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:6543/postgres"

# Direct connection for migrations (session mode, port 5432)
# Replace with your Supabase project URL
DIRECT_URL="postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres"

# --- Better-Auth ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="your-secret-key-here-at-least-32-chars"

# --- URLs ---
# For production: https://your-domain.com
# For development: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"
